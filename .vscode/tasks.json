{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Release Binary",
      "type": "process",
      "command": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
      "args": [
        "-NoProfile",
        "-File",
        "${workspaceFolder}\\.vscode\\build-release.ps1"
      ],
      "linux": {
        "command": "bash",
        "args": [
          "${workspaceFolder}/.vscode/build-release.sh"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$go",
      "detail": "Build a release-style binary for the current Windows or Linux system."
    }
  ]
}
