{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug SQLGo",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/sqlgo",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "buildFlags": "-ldflags=-linkmode=internal",
      "debugAdapter": "dlv-dap"
    },
    {
      "name": "Debug DB Tests",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/internal/db",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "debugAdapter": "dlv-dap"
    }
  ]
}
